# ============================================================
# Social Marketing AI — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Anthropic (Claude) ---
# Get from: https://console.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=sk-ant-...

# --- Facebook ---
# Get from: https://developers.facebook.com → your App → Graph API Explorer
# Page ID: your Facebook Page numeric ID
# Access Token: a Page access token with pages_manage_posts permission
FACEBOOK_PAGE_ID=123456789
FACEBOOK_ACCESS_TOKEN=EAAxxxxx...

# --- Instagram ---
# Requires Instagram Business/Creator account linked to your Facebook Page
# IG User ID: your Instagram Business account numeric ID (not username)
# Access Token: same long-lived Page token works for Instagram Graph API
INSTAGRAM_USER_ID=987654321
INSTAGRAM_ACCESS_TOKEN=EAAxxxxx...
# A publicly accessible image URL to attach to Instagram posts
# Can be a branded template image hosted on your site or a CDN
INSTAGRAM_DEFAULT_IMAGE_URL=https://yourdomain.com/images/social-template.jpg

# --- TikTok ---
# Get from: https://developers.tiktok.com → your App → Content Posting API
# Access Token: OAuth2 user access token with video.publish scope
TIKTOK_ACCESS_TOKEN=act.xxxxx...
# A publicly accessible video URL (MP4) used for TikTok posts
# TikTok requires video content — use a short branded clip
TIKTOK_VIDEO_URL=https://yourdomain.com/videos/branded-clip.mp4

# ============================================================
# Per-industry overrides (optional)
# You can create industry-specific .env files, e.g. .env.real_estate
# and load them by passing --env-file to the script in future.
# ============================================================
